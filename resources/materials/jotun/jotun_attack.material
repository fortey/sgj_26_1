name: "jotun_attack_material"
tags: "tile"
vertex_program: "/resources/materials/jotun/jotun_attack.vp"
fragment_program: "/resources/materials/jotun/jotun_attack.fp"
vertex_constants {
  name: "view_proj"
  type: CONSTANT_TYPE_VIEWPROJ
}
fragment_constants {
  name: "tint"
  type: CONSTANT_TYPE_USER
  value {
    x: 1.0
    y: 1.0
    z: 1.0
    w: 1.0
  }
}
fragment_constants {
  name: "u_brightness_time"
  type: CONSTANT_TYPE_TIME
}
fragment_constants {
  name: "u_waving_time"
  type: CONSTANT_TYPE_TIME
}
samplers {
  name: "texture_sampler"
  wrap_u: WRAP_MODE_CLAMP_TO_EDGE
  wrap_v: WRAP_MODE_CLAMP_TO_EDGE
  filter_min: FILTER_MODE_MIN_DEFAULT
  filter_mag: FILTER_MODE_MAG_DEFAULT
  max_anisotropy: 0.0
}
